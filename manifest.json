{
  "manifest_version": 3,
  "name": "IESB Chrome Extension",
  "version": "1.0.16",
  "description": "Automatiza atividades rotineiras dos docentes do IESB",
  "author": "Nominato Tecnologia",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "favicon.png",
    "32": "favicon.png",
    "48": "favicon.png",
    "128": "favicon.png"
  },
  "host_permissions": [
    "https://classroom.google.com/*",
    "https://online.iesb.br/*",
    "https://drive.google.com/*",
    "https://takeout-download-drive.usercontent.google.com/*"
  ],
  "action": {
    "default_title": "Capturar e Aplicar",
    "default_popup": "popup.html",
    "default_icon": "favicon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://classroom.google.com/*",
        "https://online.iesb.br/*",
        "https://drive.google.com/*"
      ],
      "js": [
        "utils/text-utils.js",
        "utils/date-utils.js",
        "modules/presenca-aplicacao-flow.js",
        "modules/notas-flow.js",
        "content.js"
      ]
    }
  ]
}