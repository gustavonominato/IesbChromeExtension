{
  "manifest_version": 3,
  "name": "IESB Chrome Extension",
  "version": "1.0.10",
  "description": "Automatiza atividades rotineiras dos docentes do IESB",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://classroom.google.com/*",
    "https://online.iesb.br/*",
    "https://drive.google.com/*",
    "https://takeout-download-drive.usercontent.google.com/*"
  ],
  "action": {
    "default_title": "Capturar e Aplicar",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://classroom.google.com/*",
        "https://online.iesb.br/*",
        "https://drive.google.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}